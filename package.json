{
  "name": "create-use-forge",
  "version": "0.1.4",
  "private": false,
  "description": "Create a Forge app.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://use-forge.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohamedgshoaib/forge.git"
  },
  "bugs": {
    "url": "https://github.com/mohamedgshoaib/forge/issues"
  },
  "keywords": [
    "forge",
    "create-use-forge",
    "starter",
    "scaffold",
    "cli",
    "nextjs",
    "vite",
    "tanstack-start",
    "shadcn",
    "base-ui",
    "radix-ui",
    "rtl"
  ],
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "assets/branding/favicon.ico"
  ],
  "bin": {
    "forge": "dist/index.js",
    "create-use-forge": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --platform node --target node20 --out-dir dist --clean",
    "dev": "tsx src/cli/index.ts",
    "test": "node --import tsx --test src/cli/args.test.ts src/cli/summary.test.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\""
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
